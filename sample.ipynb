    "import pynvml\n",
    "pynvml.nvmlInit()\n",
    "\n",
    "handle = pynvml.nvmlDeviceGetHandleByIndex(0)\n",
    "power = pynvml.nvmlDeviceGetPowerUsage(handle) / 1000\n",
    "\n",
    "print(f\"Power: {power} W\")"
   ]
  }
